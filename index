        }
        @keyframes floatBtn { 0% { transform: translateY(0); } 100% { transform: translateY(-6px); } }
        .fixed-btn:hover { transform: translateY(-6px) scale(1.04); box-shadow: 0 12px 36px rgba(139,108,193,0.45); }
        .fixed-btn:active { transform: scale(0.96); }

        .scroll-top {
            position: fixed; bottom: 28px; left: 28px;
            width: 46px; height: 46px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            opacity: 0; transform: translateY(12px); transition: all 0.3s ease;
            z-index: 90; box-shadow: var(--shadow);
