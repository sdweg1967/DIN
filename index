        .soc { width: 52px; height: 52px; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 600; box-shadow: var(--shadow); transition: var(--transition); }
