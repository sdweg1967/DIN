        .footer-links a:hover { color: var(--accent); padding-left: 4px; }
        .footer-bottom { border-top: 1px solid var(--border); padding-top: 28px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 0.8rem; color: var(--text-muted); }
        .legal a { color: var(--text-muted); margin-left: 20px; }
