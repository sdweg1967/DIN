        .admin-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
        .admin-content { display: none; }
        .admin-content.active { display: block; }
        .bk-item { background: var(--bg); border: 1px solid var(--border); padding: 20px; margin-bottom: 14px; border-radius: var(--radius-sm); display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 14px; }
        .bk-info h4 { font-family: var(--font-sans); font-size: 0.95rem; margin-bottom: 6px; }
        .bk-info p { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 4px; }
        .st { display: inline-block; padding: 4px 10px; font-size: 0.7rem; font-weight: 700; border-radius: 50px; margin-top: 4px; }
        .st-new { background: #FFF3E0; color: #E65100; }
        .st-ok { background: #E8F5E9; color: #2E7D32; }
        .st-cancel { background: #FFEBEE; color: #C62828; }
        .btn-sm { padding: 8px 14px; font-size: 0.75rem; font-weight: 700; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--surface); }
        .btn-sm:hover { border-color: var(--accent); color: var(--accent); }
        .login-wrap { text-align: center; padding: 30px 0; }
        .login-wrap h2 { margin-bottom: 10px; }
        .login-wrap input { max-width: 280px; padding: 12px; text-align: center; border-radius: var(--radius-sm); margin-bottom: 14px; }
        .login-btn { padding: 12px 30px; background: linear-gradient(135deg, var(--accent), var(--accent-hover)); color: white; font-weight: 700; border-radius: var(--radius-sm); border: none; box-shadow: 0 4px 14px rgba(139,108,193,0.3); }

        /* TOAST */
        .toast { position: fixed; bottom: 32px; right: 32px; background: var(--surface); border: 1px solid var(--border); padding: 16px 24px; font-size: 0.9rem; font-weight: 500; z-index: 300; opacity: 0; transform: translateY(12px); transition: all 0.35s ease; pointer-events: none; box-shadow: var(--shadow-hover); border-radius: var(--radius-sm); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .toast.show { opacity: 1; transform: translateY(0); }
