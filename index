<div class="admin-overlay" id="adminOv">
    <div class="admin-modal" id="adminModal">
        <button class="admin-close" onclick="closeAdmin()">✕</button>
        <div id="admLogin">
            <div class="login-wrap">
                <h2>Вход для мастера</h2>
