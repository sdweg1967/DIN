        /* FIXED BTN & SCROLL */
        .fixed-btn {
            position: fixed; bottom: 28px; right: 28px; z-index: 90;
            background: linear-gradient(135deg, var(--accent), var(--accent-hover));
            color: white; padding: 14px 28px; font-weight: 700; font-size: 0.9rem;
