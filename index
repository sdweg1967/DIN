<div class="toast" id="toast"></div>

<script>
    let curM = new Date().getMonth(), curY = new Date().getFullYear(), selD = null, selT = null;
    const A_PWD = 'dinara2026';
    const getB = () => JSON.parse(localStorage.getItem('d_b')||'[]');
    const setB = d => localStorage.setItem('d_b', JSON.stringify(d));
    const MN = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
    const DN = ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
    const fmt = d => `${d.getDate().toString().padStart(2,'0')}.${(d.getMonth()+1).toString().padStart(2,'0')}.${d.getFullYear()}`;

    /* ===== PARALLAX EFFECT ===== */
    const parallaxElements = document.querySelectorAll('[data-parallax-speed]');
    let ticking = false;
    window.addEventListener('scroll', () => {
        if (!ticking) {
            window.requestAnimationFrame(() => {
                const scrollY = window.pageYOffset;
                parallaxElements.forEach(el => {
                    const speed = parseFloat(el.dataset.parallaxSpeed);
                    const rect = el.parentElement.getBoundingClientRect();
                    const offset = (rect.top + scrollY) * speed;
                    el.style.transform = `translateY(${scrollY * speed * -0.5}px)`;
                });
                ticking = false;
            });
            ticking = true;
        }
    });

    /* ===== IOS HEADER SCROLL ===== */
    window.addEventListener('scroll', () => {
        const header = document.getElementById('header');
        const scrollTop = document.getElementById('scrollTop');
        header.classList.toggle('scrolled', window.scrollY > 20);
        scrollTop.classList.toggle('visible', window.scrollY > 400);

        // Active nav link
        const sections = document.querySelectorAll('section[id]');
        let current = '';
        sections.forEach(s => {
            const top = s.offsetTop - 120;
            if (scrollY >= top) current = s.id;
        });
        document.querySelectorAll('.nav a').forEach(a => {
            a.classList.toggle('active', a.getAttribute('href') === '#' + current);
        });
    });

    /* ===== MOBILE MENU ===== */
    const burger = document.getElementById('burger'), mob = document.getElementById('mobMenu');
    burger.onclick = () => { burger.classList.toggle('active'); mob.classList.toggle('active'); document.body.style.overflow = mob.classList.contains('active')?'hidden':''; };
    const closeMob = () => { burger.classList.remove('active'); mob.classList.remove('active'); document.body.style.overflow=''; };

    /* ===== REVEAL ANIMATION ===== */
    const io = new IntersectionObserver(e => e.forEach(el => el.target.classList.add('visible')), { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    /* ===== CALENDAR ===== */
    function renderCal(){
        document.getElementById('calTitle').textContent = `${MN[curM]} ${curY}`;
        document.getElementById('calNames').innerHTML = DN.map(n=>`<div class="cal-name">${n}</div>`).join('');
        const g = document.getElementById('calGrid'); g.innerHTML='';
        let s = new Date(curY,curM,1).getDay(); s = s===0?6:s-1;
        const days = new Date(curY,curM+1,0).getDate(), now = new Date(); now.setHours(0,0,0,0);
        const bks = getB();
        for(let i=0;i<s;i++) g.innerHTML += `<div class="cal-day empty"></div>`;
        for(let d=1;d<=days;d++){
            const dt = new Date(curY,curM,d); dt.setHours(0,0,0,0);
            const past = dt<now, today = dt.getTime()===now.getTime();
            const ds = fmt(dt), has = bks.some(b=>b.date===ds && b.status!=='cancel');
            let c = 'cal-day';
            if(past) c+=' past'; else {
                if(today) c+=' today'; if(selD && dt.getTime()===selD.getTime()) c+=' selected'; if(has) c+=' has';
                const el = document.createElement('div'); el.className=c; el.textContent=d;
                el.onclick=()=>pickDate(dt); g.appendChild(el); continue;
            }
            const el = document.createElement('div'); el.className=c; el.textContent=d; g.appendChild(el);
        }
    }
    function pickDate(dt){ selD=dt; selT=null; renderCal(); showTimes(dt); updInp(); }
    function showTimes(dt){
        const w = document.getElementById('timeWrap'), g = document.getElementById('timeGrid');
        w.classList.add('active'); g.innerHTML='';
        const ts = ['09:00','10:00','11:00','12:00','14:00','15:00','16:00','17:00','18:00'];
        const bks = getB(), ds = fmt(dt);
        ts.forEach(t=>{
            const e = document.createElement('div'); e.className='time-pill'; e.textContent=t;
            const booked = bks.some(b=>b.date===ds && b.time===t && b.status!=='cancel');
            if(booked) e.classList.add('booked'); else e.onclick=()=>pickTime(t,e);
            if(selT===t) e.classList.add('selected'); g.appendChild(e);
        });
    }
    function pickTime(t,el){ selT=t; document.querySelectorAll('.time-pill').forEach(p=>p.classList.remove('selected')); el.classList.add('selected'); updInp(); }
    function updInp(){ document.getElementById('selDt').value = selD ? (fmt(selD)+(selT?`, ${selT}`:'')) : ''; }
    function chgMonth(d){ curM+=d; if(curM>11){curM=0;curY++;} if(curM<0){curM=11;curY--;} renderCal(); }
    renderCal();

    /* ===== SLIDER ===== */
    const ba=document.getElementById('baSlider'), baA=document.getElementById('baAfter'), baH=document.getElementById('baHandle'); let drag=false;
    const updS = x => { const r=ba.getBoundingClientRect(); let p=Math.max(0,Math.min(100,((x-r.left)/r.width)*100)); baA.style.clipPath=`inset(0 ${100-p}% 0 0)`; baH.style.left=p+'%'; };
    baH.onmousedown=()=>drag=true; baH.ontouchstart=()=>drag=true;
    document.onmousemove=e=>drag&&updS(e.clientX); document.ontouchmove=e=>drag&&updS(e.touches[0].clientX);
    document.onmouseup=document.ontouchend=()=>drag=false; ba.onclick=e=>updS(e.clientX);

    /* ===== FORM ===== */
    document.querySelector('input[name="phone"]').addEventListener('input', function(e){
        let v=this.value.replace(/\D/g,''); if(v.length>0){ if(v[0]==='7'||v[0]==='8')v=v.substring(1); let f='+7'; if(v.length>0)f+=' ('+v.substring(0,3); if(v.length>=3)f+=') '+v.substring(3,6); if(v.length>=6)f+='-'+v.substring(6,8); if(v.length>=8)f+='-'+v.substring(8,10); this.value=f; }
    });
    function submitBook(e){
        e.preventDefault(); const fd=new FormData(e.target);
        const srv={keratin:'Кератин',botox:'Ботокс',cold:'Холодная рек.',nano:'Нанопластика'};
        const bk={id:Date.now(),name:fd.get('name'),phone:fd.get('phone'),service:srv[fd.get('service')]||fd.get('service')||'Не выбрана',date:selD?fmt(selD):'Не выбрана',time:selT||'Не выбрано',comment:fd.get('comment')||'',status:'new',created:new Date().toISOString()};
        const l=getB(); l.push(bk); setB(l);
        e.target.reset(); selD=null; selT=null; renderCal(); document.getElementById('timeWrap').classList.remove('active'); document.getElementById('selDt').value='';
        toast('✅ Заявка отправлена. Я свяжусь с вами в ближайшее время.', 'success');
    }

    /* ===== TOAST ===== */
    function toast(m,t=''){ const e=document.getElementById('toast'); e.textContent=m; e.className='toast show'; if(t) e.style.borderColor=t==='success'?'#10B981':'#EF4444'; setTimeout(()=>e.className='toast', 3500); }

    /* ===== ADMIN ===== */
    function openAdmin(e){ e.preventDefault(); document.getElementById('adminOv').classList.add('active'); document.body.style.overflow='hidden'; }
    function closeAdmin(){ document.getElementById('adminOv').classList.remove('active'); document.body.style.overflow=''; }
    document.getElementById('adminOv').onclick=e=>e.target===document.getElementById('adminOv')&&closeAdmin();
    function loginAdm(){ if(document.getElementById('admPwd').value===A_PWD){ document.getElementById('admLogin').style.display='none'; document.getElementById('admPanel').style.display='block'; renderBkList(); renderAdmCal(); toast('✅ Добро пожаловать, Динара.', 'success'); } else toast('❌ Неверный пароль', 'error'); }
    function switchTab(t,btn){ document.querySelectorAll('.admin-tab').forEach(x=>x.classList.remove('active')); document.querySelectorAll('.admin-content').forEach(x=>x.classList.remove('active')); btn.classList.add('active'); document.getElementById('tab-'+t).classList.add('active'); if(t==='cal') renderAdmCal(); }
    function renderBkList(){
        const l=document.getElementById('bkList'), bks=getB().sort((a,b)=>b.id-a.id);
        if(!bks.length){l.innerHTML='<p class="muted" style="text-align:center;padding:30px 0;">Заявок пока нет</p>';return;}
        l.innerHTML=bks.map(b=>{
            const st=b.status==='new'?'st-new':b.status==='ok'?'st-ok':'st-cancel';
            const txt=b.status==='new'?'НОВАЯ':b.status==='ok'?'ПОДТВЕРЖДЕНА':'ОТМЕНЕНА';
            return `<div class="bk-item"><div class="bk-info"><h4>${b.name} — ${b.service}</h4><p>📅 ${b.date} | 🕐 ${b.time} | 📞 ${b.phone}</p>${b.comment?`<p style="margin-top:4px;font-style:italic;">«${b.comment}»</p>`:''}<span class="st ${st}">${txt}</span></div><div>${b.status==='new'?`<button class="btn-sm" onclick="updB(${b.id},'ok')">Подтвердить</button> <button class="btn-sm" onclick="updB(${b.id},'cancel')">Отменить</button>`:''}</div></div>`;
        }).join('');
    }
    function updB(id,s){ const b=getB(); const i=b.findIndex(x=>x.id===id); if(i!==-1){b[i].status=s; setB(b); renderBkList(); renderAdmCal(); renderCal(); toast(s==='ok'?'✅ Заявка подтверждена':'❌ Заявка отменена'); } }
    function renderAdmCal(){
        const w=document.getElementById('admCal'), bks=getB(), g={};
        bks.forEach(b=>{if(b.date!=='Не выбрана'){g[b.date]=g[b.date]||[];g[b.date].push(b);}});
        if(!Object.keys(g).length){w.innerHTML='<p class="muted" style="text-align:center;padding:30px 0;">Записей пока нет</p>';return;}
        w.innerHTML=Object.entries(g).sort().map(([d,its])=>`<div class="bk-item"><div class="bk-info"><h4>📅 ${d}</h4>${its.map(i=>`<p>🕐 ${i.time} — ${i.name} <span class="st ${i.status==='new'?'st-new':i.status==='ok'?'st-ok':'st-cancel'}">${i.status==='new'?'НОВАЯ':i.status==='ok'?'ПОДТВЕРЖДЕНА':'ОТМЕНЕНА'}</span></p>`).join('')}</div></div>`).join('');
    }
</script>
</body>
</html>
