                <button class="admin-tab" onclick="switchTab('cal', this)">Календарь</button>
            </div>
            <div class="admin-content active" id="tab-bk">
                <div id="bkList"><p class="muted" style="text-align:center;padding:30px 0;">Заявок пока нет</p></div>
            </div>
            <div class="admin-content" id="tab-cal">
